# 崖山数据库 MCP Server 环境变量配置
# 复制此文件为 .env 并修改配置

# ============================================
# 数据库连接配置（必填）
# ============================================

# 数据库主机地址
DB_HOST=localhost

# 数据库端口
DB_PORT=1688

# 数据库名称
DB_NAME=yashandb

# 数据库用户名
DB_USER=your_username

# 数据库密码
DB_PASSWORD=your_password

# ============================================
# JDBC 高级配置（可选）
# ============================================

# JDBC 驱动类名（默认：com.yashandb.jdbc.Driver）
# DB_DRIVER_CLASS=com.yashandb.jdbc.Driver

# JDBC URL（可选，默认自动生成）
# DB_JDBC_URL=jdbc:yasdb://localhost:1688/yashandb

# ============================================
# JVM 配置（可选，自动检测）
# ============================================

# JVM 库路径（如果自动检测失败，请手动设置）
# Mac 示例：
# JVM_LIB=/Library/Java/JavaVirtualMachines/jdk-17.jdk/Contents/Home/lib/server/libjvm.dylib
# Linux 示例：
# JVM_LIB=/usr/lib/jvm/java-17-openjdk/lib/server/libjvm.so
# Windows 示例：
# JVM_LIB=C:\Program Files\Java\jdk-17\bin\server\jvm.dll

# ============================================
# 日志配置（可选）
# ============================================

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 日志文件路径（可选，默认：yashan_mcp.log）
# LOG_FILE=yashan_mcp.log

# ============================================
# 连接池配置（可选）
# ============================================

# 最大连接数（默认：5）
# MAX_CONNECTIONS=5

# 连接超时时间（秒，默认：30）
# CONNECTION_TIMEOUT=30
