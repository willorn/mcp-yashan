# 崖山数据库 MCP SSE Server 环境变量配置
# 复制此文件为 .env 并修改配置

# ============================================
# 数据库连接配置（必填）
# ============================================

# 数据库主机地址
DB_HOST=localhost

# 数据库端口
DB_PORT=1688

# 数据库名称
DB_NAME=yashandb

# 数据库用户名
DB_USER=your_username

# 数据库密码
DB_PASSWORD=your_password

# ============================================
# JDBC 高级配置（可选）
# ============================================

# JDBC URL（可选，默认自动生成）
# DB_JDBC_URL=jdbc:yasdb://localhost:1688/yashandb?failover=on

# ============================================
# 日志配置（可选）
# ============================================

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
