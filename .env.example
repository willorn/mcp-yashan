# 崖山数据库 MCP Server 环境变量配置
# 复制此文件为 .env 并修改配置

# 数据库地址
DB_HOST=localhost

# 数据库端口
DB_PORT=1688

# 数据库名称
DB_NAME=yashandb

# 数据库用户名
DB_USER=your_username

# 数据库密码
DB_PASSWORD=your_password

# JDBC 驱动类名（一般不需要修改）
# DB_DRIVER_CLASS=com.yashandb.jdbc.Driver

# 完整的 JDBC URL（如果设置了此项，DB_HOST/DB_PORT/DB_NAME 会被忽略）
# DB_JDBC_URL=jdbc:yasdb://localhost:1688/yashandb

# JVM 路径（可选，自动检测）
# JVM_LIB=/path/to/libjvm.so
